# Production .env template for RETC-CTS.
#
# Copy this to .env on the production server, fill in every blank, then run
# `php artisan key:generate` if APP_KEY is still empty. Never commit the
# real, filled-in .env — this file only exists as a reference; it contains
# no real secrets. See the Deployment Checklist for the full rollout steps.

APP_NAME="RETC-CTS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=th
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# "daily" (not "single") so logs rotate instead of growing into one huge
# file, and "error" (not "debug") so routine request noise isn't logged.
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=retc_cts_prod
DB_USERNAME=
DB_PASSWORD=

# Paths to the MySQL CLI tools used by Settings > Backup/Restore and the
# scheduled `backup:database` command. On most Linux hosting (including
# HostAtom) these are simply on PATH already — confirm with:
#   which mysqldump && which mysql
MYSQLDUMP_PATH=mysqldump
MYSQL_CLI_PATH=mysql

# database-backed sessions survive app deploys/restarts (unlike "file"),
# and multiple PHP-FPM workers/servers all read the same session table.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# true because APP_URL is https:// — the browser will refuse to send this
# cookie back over a plain http:// connection at all, which is the point.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

# LINE Messaging API channel access token (LINE Notify was discontinued).
# Get this from the LINE Developers console for your Official Account.
LINE_CHANNEL_ACCESS_TOKEN=

# Comma-separated IP(s)/CIDR of any reverse proxy or load balancer in front
# of the app (e.g. Cloudflare, Nginx). Leave blank if the app server is
# reached directly with no proxy in front of it. See bootstrap/app.php.
TRUSTED_PROXIES=

# Where the scheduled backup:database command's failure emails go — set to
# a real admin address you actually read. Falls back to MAIL_FROM_ADDRESS
# if left blank (see routes/console.php).
BACKUP_NOTIFY_EMAIL=

VITE_APP_NAME="${APP_NAME}"
